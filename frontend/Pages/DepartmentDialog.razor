@inject ApiClient Api

<MudDialog>
    <TitleContent>@(IsEdit ? "Edytuj oddział" : "Nowy oddział")</TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="Model.Name" Label="Nazwa" Required="true" RequiredError="Wymagane" />
            <MudTextField @bind-Value="Model.Code" Label="Kod" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Anuluj</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Zapisz</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DepartmentFormModel Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public Guid? ItemId { get; set; }

    private MudForm _form = null!;

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        var payload = new { name = Model.Name, code = Model.Code };
        var res = IsEdit && ItemId.HasValue
            ? await Api.UpdateDepartmentAsync(ItemId.Value, payload)
            : await Api.CreateDepartmentAsync(payload);

        MudDialog.Close(res.IsSuccessStatusCode ? DialogResult.Ok(true) : DialogResult.Cancel());
    }

    private void Cancel() => MudDialog.Cancel();
}
